<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_overlay"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <ImageView
        android:id="@+id/imageViewLock"
        style="@style/PlayerControlButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/lock_controls"
        android:src="@drawable/ic_baseline_lock_open"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayoutControlUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_control_pill"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@id/exo_rew"
            style="@style/PlayerControlButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/rewind"
            android:src="@drawable/ic_baseline_replay" />

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@id/exo_play"
                style="@style/PlayerPrimaryControlButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_baseline_play_arrow" />

            <ImageView
                android:id="@id/exo_pause"
                style="@style/PlayerPrimaryControlButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/pause"
                android:src="@drawable/ic_baseline_pause" />
        </FrameLayout>

        <ImageView
            android:id="@id/exo_ffwd"
            style="@style/PlayerControlButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/fast_forward"
            android:src="@drawable/ic_baseline_forward" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutControlBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_panel"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@id/exo_position"
                style="@style/PlayerTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                style="@style/PlayerTimeTextMuted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="@string/time_separator" />

            <TextView
                android:id="@id/exo_duration"
                style="@style/PlayerTimeTextMuted"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/imageViewFullScreen"
                style="@style/PlayerControlButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/enter_full_screen"
                android:src="@drawable/ic_baseline_fullscreen" />
        </LinearLayout>

        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            app:bar_height="4dp"
            app:buffered_color="@color/player_buffered"
            app:played_color="@color/player_accent"
            app:scrubber_color="@color/player_accent"
            app:scrubber_dragged_size="18dp"
            app:scrubber_enabled_size="14dp"
            app:unplayed_color="@color/player_unplayed" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
